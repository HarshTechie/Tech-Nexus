# Environment
NODE_ENV=development

# Server
PORT=5000
HOST=0.0.0.0

# MongoDB Atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGODB_URL=mongodb+srv://user:password@your-cluster.mongodb.net/technexus?retryWrites=true&w=majority
# DATABASE_URL=  # alternative to MONGODB_URL

# MongoDB connection resilience
MONGODB_CONNECT_RETRIES=5
MONGODB_CONNECT_RETRY_DELAY_MS=5000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
MONGODB_SOCKET_TIMEOUT_MS=45000

# JWT (use 32+ random characters in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRE=1h
JWT_REFRESH_EXPIRE=7d

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
ALLOW_VERCEL_PREVIEWS=false

# Payment — Stripe (test keys from dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_xxxxx
FRONTEND_URL=http://localhost:3000

# Google Gemini AI (server-side ONLY — never put in frontend .env)
# If a key was exposed, revoke it in Google Cloud Console and create a new one.
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
AI_USE_FALLBACK=true

# Checkout / E-commerce
FREE_DELIVERY_THRESHOLD=999
SHIPPING_CHARGE=49
GST_RATE=0.18
BUSINESS_DAYS_MIN=5
BUSINESS_DAYS_MAX=7

# Rate limiting — general API
RATE_LIMIT_WINDOW_MS=15000
RATE_LIMIT_MAX_REQUESTS=100

# Rate limiting — AI endpoints (/api/ai/*)
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX_REQUESTS=10

# Logging (production: info or warn)
LOG_LEVEL=debug

# PRODUCTION ENVIRONMENT
NODE_ENV=production

# Server
PORT=5000
HOST=0.0.0.0

# MongoDB Atlas (required)
DATABASE_URL=mongodb+srv://user:password@your-cluster.mongodb.net/technexus?retryWrites=true&w=majority
MONGODB_CONNECT_RETRIES=5
MONGODB_CONNECT_RETRY_DELAY_MS=5000

# JWT (required — minimum 32 characters)
JWT_SECRET=generate-random-32-char-key-using-crypto.randomBytes
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# CORS (required — exact production frontend origin(s), comma-separated)
CORS_ORIGIN=https://your-frontend-domain.com
ALLOW_VERCEL_PREVIEWS=false

# Stripe (required — live keys)
STRIPE_SECRET_KEY=sk_live_xxxxx
FRONTEND_URL=https://your-frontend-domain.com

# Gemini AI (required in production)
# Revoke and regenerate if the key was ever exposed.
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
AI_USE_FALLBACK=true

# Checkout
FREE_DELIVERY_THRESHOLD=999
SHIPPING_CHARGE=49
GST_RATE=0.18

# Rate limiting (stricter in production)
RATE_LIMIT_WINDOW_MS=15000
RATE_LIMIT_MAX_REQUESTS=50
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX_REQUESTS=10

# Logging
LOG_LEVEL=info
